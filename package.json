{
  "name": "wordstockt-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "dev:prod-api": "EXPO_PUBLIC_USE_PRODUCTION=true expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "web": "expo start --web",
    "build": "eas build --profile development --platform ios",
    "build:prod": "eas build --profile production --platform ios",
    "build:all": "eas build --profile development --platform all",
    "update": "eas update --channel development",
    "update:prod": "eas update --channel production",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
