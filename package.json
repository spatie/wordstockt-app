    "@sentry/react-native": "~7.2.0",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "^5.90.16",
    "axios": "^1.13.2",
    "babel-preset-expo": "^54.0.9",
    "expo": "~54.0.31",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.12",
    "expo-dev-client": "~6.0.20",
